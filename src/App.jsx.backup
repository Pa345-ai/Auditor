import { useState, useCallback } from "react";

const SEV = {
  CRITICAL: { color: '#ff3b3b', bg: 'rgba(255,59,59,0.12)', border: 'rgba(255,59,59,0.3)', icon: '💀' },
  HIGH:     { color: '#ff8c42', bg: 'rgba(255,140,66,0.1)',  border: 'rgba(255,140,66,0.3)', icon: '🔴' },
  MEDIUM:   { color: '#ffd166', bg: 'rgba(255,209,102,0.1)', border: 'rgba(255,209,102,0.3)', icon: '🟡' },
  LOW:      { color: '#06d6a0', bg: 'rgba(6,214,160,0.1)',   border: 'rgba(6,214,160,0.3)', icon: '🟢' },
  INFO:     { color: '#8ecae6', bg: 'rgba(142,202,230,0.1)', border: 'rgba(142,202,230,0.3)', icon: 'ℹ️' },
};
const SEV_ORDER = ['CRITICAL','HIGH','MEDIUM','LOW','INFO'];

function parseGitHubUrl(url) {
  const match = url.trim().match(/github\.com\/([^/\s]+)\/([^/\s?#]+)/);
  if (!match) return null;
  return { owner: match[1], repo: match[2].replace(/\.git$/, '') };
}

function extractJson(text) {
  const fence = text.match(/```(?:json)?\s*([\s\S]*?)```/);
  if (fence) return fence[1].trim();
  const brace = text.match(/(\{[\s\S]*\})/);
  if (brace) return brace[1].trim();
  return text.trim();
}

async function gemini(apiKey, prompt, useSearch = false) {
  const body = {
    contents: [{ role: "user", parts: [{ text: prompt }] }],
    generationConfig: { temperature: 0.1, maxOutputTokens: 8192 },
  };
  if (useSearch) {
    body.tools = [{ google_search: {} }];
  }
  const model = "gemini-2.0-flash";
  const res = await fetch(
    `https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${apiKey}`,
    { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(body) }
  );
  const data = await res.json();
  if (data.error) throw new Error(data.error.message);
  return data.candidates?.[0]?.content?.parts?.map(p => p.text || "").join("") || "";
}

function ScoreRing({ score }) {
  const r = 52, circ = 2 * Math.PI * r, filled = (score / 100) * circ;
  const color = score >= 80 ? '#06d6a0' : score >= 55 ? '#ffd166' : score >= 30 ? '#ff8c42' : '#ff3b3b';
  return (
    <div style={{ position:'relative', width:130, height:130, flexShrink:0 }}>
      <svg width="130" height="130" style={{ transform:'rotate(-90deg)' }}>
        <circle cx="65" cy="65" r={r} fill="none" stroke="rgba(255,255,255,0.07)" strokeWidth="9"/>
        <circle cx="65" cy="65" r={r} fill="none" stroke={color} strokeWidth="9"
          strokeDasharray={`${filled} ${circ}`} strokeLinecap="round"
          style={{ transition:'stroke-dasharray 1.4s cubic-bezier(.4,0,.2,1)', filter:`drop-shadow(0 0 10px ${color})` }}/>
      </svg>
      <div style={{ position:'absolute', inset:0, display:'flex', flexDirection:'column', alignItems:'center', justifyContent:'center' }}>
        <div style={{ fontSize:30, fontWeight:800, color, fontFamily:'monospace', lineHeight:1 }}>{score}</div>
        <div style={{ fontSize:9, color:'rgba(255,255,255,0.35)', letterSpacing:2, marginTop:2 }}>SCORE</div>
      </div>
    </div>
  );
}

function VulnCard({ vuln }) {
  const [open, setOpen] = useState(false);
  const cfg = SEV[vuln.severity] || SEV.INFO;
  return (
    <div onClick={() => setOpen(o => !o)} style={{
      background: open ? cfg.bg : 'rgba(255,255,255,0.025)',
      border: `1px solid ${open ? cfg.border : 'rgba(255,255,255,0.07)'}`,
      borderRadius:10, marginBottom:8, cursor:'pointer', transition:'all 0.18s'
    }}>
      <div style={{ display:'flex', alignItems:'center', gap:12, padding:'12px 16px' }}>
        <span style={{ fontSize:16 }}>{cfg.icon}</span>
        <div style={{ flex:1, minWidth:0 }}>
          <div style={{ display:'flex', alignItems:'center', gap:8, flexWrap:'wrap' }}>
            <span style={{ fontSize:10, fontWeight:700, letterSpacing:1.5, padding:'2px 7px', borderRadius:4,
              background:cfg.bg, color:cfg.color, border:`1px solid ${cfg.border}`, fontFamily:'monospace' }}>
              {vuln.severity}
            </span>
            <span style={{ fontSize:13, fontWeight:600, color:'rgba(255,255,255,0.9)' }}>{vuln.title}</span>
          </div>
          {vuln.file && (
            <div style={{ fontSize:11, color:'rgba(255,255,255,0.3)', marginTop:3, fontFamily:'monospace',
              overflow:'hidden', textOverflow:'ellipsis', whiteSpace:'nowrap' }}>
              {vuln.file}{vuln.line ? `:${vuln.line}` : ''}
            </div>
          )}
        </div>
        <span style={{ color:'rgba(255,255,255,0.25)', fontSize:11, transform:open?'rotate(180deg)':'none', transition:'0.2s' }}>▼</span>
      </div>
      {open && (
        <div style={{ padding:'0 16px 16px', borderTop:`1px solid ${cfg.border}` }}>
          <div style={{ marginTop:12, display:'grid', gap:10 }}>
            {[
              ['DESCRIPTION', vuln.description, cfg.color],
              ['IMPACT', vuln.impact, '#ff8c42'],
              ['RECOMMENDATION', vuln.recommendation, '#06d6a0']
            ].filter(([,v]) => v).map(([label, val, col]) => (
              <div key={label}>
                <div style={{ fontSize:10, fontWeight:700, color:col, letterSpacing:1.5, marginBottom:4 }}>{label}</div>
                <div style={{ fontSize:13, color:'rgba(255,255,255,0.65)', lineHeight:1.6 }}>{val}</div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}

export default function App() {
  const [apiKey, setApiKey] = useState('');
  const [url, setUrl]       = useState('');
  const [logs, setLogs]     = useState([]);
  const [progress, setProgress] = useState(0);
  const [loading, setLoading]   = useState(false);
  const [report, setReport]     = useState(null);
  const [repoName, setRepoName] = useState('');
  const [filter, setFilter]     = useState('ALL');
  const [error, setError]       = useState('');

  const addLog = (msg, prog) => {
    setLogs(l => [...l, msg]);
    if (prog !== undefined) setProgress(prog);
  };

  const audit = useCallback(async () => {
    const parsed = parseGitHubUrl(url);
    if (!parsed) { setError('Enter a valid GitHub URL e.g. https://github.com/facebook/react'); return; }
    if (!apiKey.trim()) { setError('Enter your Gemini API key above'); return; }

    setLoading(true); setReport(null); setError('');
    setLogs([]); setProgress(0); setFilter('ALL');
    setRepoName(`${parsed.owner}/${parsed.repo}`);

    try {
      // Phase 1 — gather code via Gemini + Google Search grounding
      addLog('Searching GitHub via Gemini + Google Search…', 8);

      const gatherPrompt = `You are a security researcher. Search the web and retrieve as much source code as possible from this GitHub repository: https://github.com/${parsed.owner}/${parsed.repo}

Do the following:
1. Search for "${parsed.owner} ${parsed.repo} github source code"
2. Look for the README, package.json / requirements.txt / go.mod / Cargo.toml, main entry files, authentication files, API route files, config files, database files, middleware, and any file containing "secret", "token", "key", "password", "auth" in its name
3. Try to access gitingest content for this repo
4. Retrieve as many actual file contents as possible

Output everything you find in this format:
REPO_SUMMARY: [what it does, language, framework, stars]
FILE_CONTENTS:
=== path/filename ===
[full content]
=== path/filename2 ===
[full content]`;

      const gathered = await gemini(apiKey, gatherPrompt, true);
      addLog(`Gathered ${Math.round(gathered.length / 1000)}KB of repo data. Running security analysis…`, 55);

      // Phase 2 — security audit
      const auditPrompt = `You are a senior application security engineer with deep expertise in OWASP Top 10, SANS Top 25, and CWE.

Repository: ${parsed.owner}/${parsed.repo}

Gathered source code and repo info:
${gathered.slice(0, 100000)}

Perform a comprehensive security audit. Check for ALL of:
- Hardcoded secrets, API keys, tokens, passwords, private keys
- SQL / NoSQL / command / LDAP / XPath injection
- Broken authentication and session management
- Insecure direct object references (IDOR)
- Cross-site scripting (XSS) and CSRF
- Server-side request forgery (SSRF)
- Path traversal / directory traversal
- Insecure deserialization
- Weak or broken cryptography
- Missing or misconfigured security headers
- Sensitive data exposure
- Open redirect vulnerabilities
- Prototype pollution
- ReDoS (regular expression denial of service)
- Insecure third-party dependencies (known CVEs)
- Information leakage in error messages or logs
- Race conditions
- XML external entity (XXE) injection
- Insecure file uploads

You MUST respond with ONLY valid JSON. No explanation, no markdown, no backticks. Just raw JSON:
{
  "summary": "2-3 sentence honest executive summary of this repo's security posture",
  "score": <integer 0-100 where 100 is perfectly secure and 0 is critically vulnerable>,
  "vulnerabilities": [
    {
      "severity": "CRITICAL",
      "title": "Hardcoded AWS Secret Key",
      "file": "config/aws.js",
      "line": "12",
      "description": "AWS secret access key is hardcoded directly in the source file",
      "impact": "Full AWS account compromise — attacker can access all cloud resources",
      "recommendation": "Move to environment variables. Use AWS IAM roles or secrets manager."
    }
  ],
  "positives": ["Uses bcrypt for password hashing", "HTTPS enforced in production"],
  "stats": {"critical": 1, "high": 0, "medium": 0, "low": 0, "info": 0}
}`;

      addLog('Analyzing vulnerabilities with Gemini…', 70);
      const analysisRaw = await gemini(apiKey, auditPrompt, false);

      addLog('Processing findings…', 90);
      const clean = extractJson(analysisRaw);
      const result = JSON.parse(clean);

      // Recount stats
      result.stats = { critical:0, high:0, medium:0, low:0, info:0 };
      (result.vulnerabilities || []).forEach(v => {
        const k = v.severity?.toLowerCase();
        if (k in result.stats) result.stats[k]++;
      });

      setReport(result);
      setProgress(100);
      addLog(`✓ Audit complete — ${result.vulnerabilities?.length || 0} findings`, 100);

    } catch (err) {
      setError(err.message);
      addLog('Error: ' + err.message);
    } finally {
      setLoading(false);
    }
  }, [url, apiKey]);

  const vulns = (report?.vulnerabilities || [])
    .filter(v => filter === 'ALL' || v.severity === filter)
    .sort((a, b) => SEV_ORDER.indexOf(a.severity) - SEV_ORDER.indexOf(b.severity));

  return (
    <div style={{ minHeight:'100vh', background:'#08090f', color:'#dde1ed', fontFamily:'system-ui,sans-serif',
      backgroundImage:'radial-gradient(ellipse 60% 40% at 10% 0%,rgba(255,59,59,0.06) 0%,transparent 70%)' }}>

      {/* Nav */}
      <div style={{ borderBottom:'1px solid rgba(255,255,255,0.07)', padding:'14px 24px', display:'flex', alignItems:'center', gap:10 }}>
        <div style={{ width:30,height:30,borderRadius:7,background:'rgba(255,59,59,0.15)',border:'1px solid rgba(255,59,59,0.25)',display:'flex',alignItems:'center',justifyContent:'center',fontSize:15 }}>🛡️</div>
        <span style={{ fontSize:14,fontWeight:700 }}>RepoAudit</span>
        <span style={{ fontSize:9,color:'rgba(255,255,255,0.25)',letterSpacing:2 }}>SECURITY SCANNER</span>
        <div style={{ marginLeft:'auto',display:'flex',alignItems:'center',gap:5 }}>
          <div style={{ width:6,height:6,borderRadius:'50%',background:'#4285f4',boxShadow:'0 0 6px #4285f4' }}/>
          <span style={{ fontSize:10,color:'rgba(255,255,255,0.2)' }}>gemini + google search</span>
        </div>
      </div>

      <div style={{ maxWidth:820, margin:'0 auto', padding:'32px 18px' }}>
        <h1 style={{ fontSize:24,fontWeight:700,letterSpacing:-0.5,margin:'0 0 6px' }}>GitHub Security Audit</h1>
        <p style={{ fontSize:13,color:'rgba(255,255,255,0.38)',margin:'0 0 24px' }}>
          Powered by Gemini + Google Search — fetches your repo and finds every vulnerability
        </p>

        {/* API Key input */}
        <div style={{ marginBottom:10 }}>
          <label style={{ fontSize:11,color:'rgba(255,255,255,0.35)',letterSpacing:1,display:'block',marginBottom:5 }}>GEMINI API KEY</label>
          <input
            type="password"
            value={apiKey}
            onChange={e => setApiKey(e.target.value)}
            placeholder="AIza…"
            style={{ width:'100%', padding:'11px 14px', boxSizing:'border-box',
              background:'rgba(255,255,255,0.04)', border:'1px solid rgba(255,255,255,0.08)',
              borderRadius:9, color:'#dde1ed', fontSize:13, fontFamily:'monospace', outline:'none' }}
          />
        </div>

        {/* Repo URL + button */}
        <div style={{ display:'flex', gap:8, marginBottom:16 }}>
          <input
            value={url}
            onChange={e => { setUrl(e.target.value); setError(''); }}
            onKeyDown={e => e.key === 'Enter' && !loading && audit()}
            placeholder="https://github.com/owner/repository"
            style={{ flex:1, padding:'12px 14px',
              background:'rgba(255,255,255,0.05)', border:'1px solid rgba(255,255,255,0.1)',
              borderRadius:9, color:'#dde1ed', fontSize:13, fontFamily:'monospace', outline:'none' }}
          />
          <button onClick={audit} disabled={loading || !url.trim() || !apiKey.trim()} style={{
            padding:'12px 22px', borderRadius:9, border:'none', fontWeight:600, fontSize:13,
            cursor: loading || !url.trim() || !apiKey.trim() ? 'not-allowed' : 'pointer', whiteSpace:'nowrap',
            background: loading ? 'rgba(255,59,59,0.25)' : 'rgba(255,59,59,0.9)',
            color: loading ? 'rgba(255,255,255,0.4)' : '#fff',
            boxShadow: loading ? 'none' : '0 0 16px rgba(255,59,59,0.3)', transition:'all 0.2s'
          }}>
            {loading ? 'Scanning…' : 'Run Audit →'}
          </button>
        </div>

        {error && (
          <div style={{ fontSize:13, color:'#ff3b3b', background:'rgba(255,59,59,0.08)',
            border:'1px solid rgba(255,59,59,0.2)', borderRadius:8, padding:'10px 14px', marginBottom:14 }}>
            ⚠ {error}
          </div>
        )}

        {/* Progress log */}
        {loading && (
          <div style={{ marginBottom:24, background:'rgba(255,255,255,0.02)', border:'1px solid rgba(255,255,255,0.06)', borderRadius:10, padding:'14px 16px' }}>
            <div style={{ display:'flex', justifyContent:'space-between', marginBottom:8 }}>
              <span style={{ fontSize:10, color:'rgba(255,255,255,0.3)', letterSpacing:2 }}>LIVE LOG</span>
              <span style={{ fontSize:10, color:'#ff8c42', fontWeight:600 }}>{progress}%</span>
            </div>
            <div style={{ height:2, background:'rgba(255,255,255,0.05)', borderRadius:1, marginBottom:12, overflow:'hidden' }}>
              <div style={{ height:'100%', width:`${progress}%`, background:'linear-gradient(90deg,#ff3b3b,#ff8c42)', transition:'width 0.5s ease', boxShadow:'0 0 8px rgba(255,59,59,0.4)' }}/>
            </div>
            {logs.map((l, i) => (
              <div key={i} style={{ fontSize:11, fontFamily:'monospace', marginBottom:3,
                color: i === logs.length-1 ? 'rgba(255,255,255,0.6)' : 'rgba(255,255,255,0.2)' }}>
                {i === logs.length-1 ? '▶ ' : '  '}{l}
              </div>
            ))}
          </div>
        )}

        {/* Report */}
        {report && !loading && (
          <div>
            {/* Summary */}
            <div style={{ background:'rgba(255,255,255,0.03)', border:'1px solid rgba(255,255,255,0.08)',
              borderRadius:12, padding:'20px 22px', marginBottom:16,
              display:'flex', gap:22, alignItems:'center', flexWrap:'wrap' }}>
              <ScoreRing score={report.score ?? 0} />
              <div style={{ flex:1, minWidth:200 }}>
                <div style={{ fontSize:15, fontWeight:700, fontFamily:'monospace', marginBottom:8 }}>{repoName}</div>
                <p style={{ fontSize:13, color:'rgba(255,255,255,0.5)', lineHeight:1.65, margin:'0 0 12px' }}>{report.summary}</p>
                <div style={{ display:'flex', gap:10, flexWrap:'wrap' }}>
                  {SEV_ORDER.map(s => {
                    const cnt = report.stats?.[s.toLowerCase()] || 0;
                    if (!cnt) return null;
                    return (
                      <div key={s} style={{ display:'flex', alignItems:'center', gap:5 }}>
                        <div style={{ width:7, height:7, borderRadius:'50%', background:SEV[s].color, boxShadow:`0 0 4px ${SEV[s].color}` }}/>
                        <span style={{ fontSize:12, color:'rgba(255,255,255,0.45)' }}>
                          <span style={{ color:SEV[s].color, fontWeight:700 }}>{cnt}</span> {s.toLowerCase()}
                        </span>
                      </div>
                    );
                  })}
                  {Object.values(report.stats||{}).every(v => !v) && (
                    <span style={{ fontSize:12, color:'#06d6a0' }}>✓ No vulnerabilities detected</span>
                  )}
                </div>
              </div>
            </div>

            {/* Filter + findings */}
            {report.vulnerabilities?.length > 0 && (
              <>
                <div style={{ display:'flex', alignItems:'center', justifyContent:'space-between', marginBottom:10, flexWrap:'wrap', gap:8 }}>
                  <span style={{ fontSize:13, fontWeight:600, color:'rgba(255,255,255,0.6)' }}>
                    Findings ({report.vulnerabilities.length})
                  </span>
                  <div style={{ display:'flex', gap:5, flexWrap:'wrap' }}>
                    {['ALL', ...SEV_ORDER.filter(s => report.stats?.[s.toLowerCase()])].map(f => (
                      <button key={f} onClick={() => setFilter(f)} style={{
                        padding:'3px 10px', borderRadius:6, fontSize:11, fontWeight:600, cursor:'pointer',
                        background: filter===f ? (SEV[f]?.bg||'rgba(255,255,255,0.1)') : 'transparent',
                        color: filter===f ? (SEV[f]?.color||'#fff') : 'rgba(255,255,255,0.28)',
                        border: `1px solid ${filter===f ? (SEV[f]?.border||'rgba(255,255,255,0.2)') : 'rgba(255,255,255,0.08)'}`,
                        transition:'all 0.15s'
                      }}>
                        {f}{f !== 'ALL' && ` (${report.stats[f.toLowerCase()]})`}
                      </button>
                    ))}
                  </div>
                </div>
                {vulns.map((v, i) => <VulnCard key={i} vuln={v}/>)}
              </>
            )}

            {/* Positives */}
            {report.positives?.length > 0 && (
              <div style={{ background:'rgba(6,214,160,0.05)', border:'1px solid rgba(6,214,160,0.15)', borderRadius:10, padding:'16px 18px', marginTop:14 }}>
                <div style={{ fontSize:11, fontWeight:700, color:'#06d6a0', letterSpacing:1.5, marginBottom:8 }}>✓ SECURITY POSITIVES</div>
                <ul style={{ margin:0, padding:'0 0 0 16px' }}>
                  {report.positives.map((p,i) => <li key={i} style={{ fontSize:13, color:'rgba(255,255,255,0.55)', lineHeight:1.7 }}>{p}</li>)}
                </ul>
              </div>
            )}
          </div>
        )}

        {/* Empty state */}
        {!loading && !report && !error && (
          <div style={{ textAlign:'center', padding:'60px 0', color:'rgba(255,255,255,0.12)' }}>
            <div style={{ fontSize:44, marginBottom:12 }}>🔍</div>
            <div style={{ fontSize:13 }}>Enter your Gemini API key + a GitHub URL, then press <strong style={{ color:'rgba(255,255,255,0.2)' }}>Run Audit</strong></div>
            <div style={{ fontSize:11, marginTop:6 }}>Gemini uses Google Search to fetch the repo — works on any public project</div>
          </div>
        )}
      </div>
    </div>
  );
}
